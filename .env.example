# Same-origin path: browser calls /api/v1/* and Next rewrites it to the backend
# (see next.config.ts), so there is no cross-origin request and no CORS.
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Backend the /api/v1 rewrite proxies to (used by next.config.ts, server-side).
API_ORIGIN=http://localhost:8080
